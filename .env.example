# Pixel Office configuration
# Copy this file to .env and adjust values as needed.

# HTTP server port
PORT=19000

# Optional Gemini API key fallback for the dashboard
GEMINI_API_KEY=

# Directory for runtime data (logs, cached config, agent messages, etc.)
# Can be absolute or relative to services/pixel/
PIXEL_DATA_DIR=./data

# Admin password for the Pixel dashboard login
DASHBOARD_PASSWORD=pixeladmin
